APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# SQLite: milliseconds to wait when another connection holds the DB (default 10000 in config).
# DB_SQLITE_BUSY_TIMEOUT=15000

# Queue on its own SQLite file (recommended when DB_CONNECTION=sqlite and QUEUE_CONNECTION=database).
# 1) Create an empty file: database/queue.sqlite
# 2) Run: php artisan migrate --database=sqlite_queue --path=database/migrations/0001_01_01_000002_create_jobs_table.php
DB_QUEUE_CONNECTION=sqlite_queue
# QUEUE_FAILED_DATABASE and QUEUE_BATCH_DATABASE default to DB_QUEUE_CONNECTION when set

# With SQLite, "database" sessions fight imports/queue jobs for the same .sqlite file → "database is locked".
# Use "file" locally; use "database" or Redis when on MySQL/PostgreSQL at scale.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Must exceed your longest job (imports can take minutes). Default 90 can re-queue long jobs.
# DB_QUEUE_RETRY_AFTER=3660

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
ADMIN_REPORT_EMAIL="jessica.g.rodriguez.chim@gmail.com"
ADMIN_REPORT_EMAILS="jessicarodrich.95@gmail.com"
SEND_COPY_TO_SANDBOX=false

REAL_MAIL_SCHEME=tls
REAL_MAIL_HOST=smtp.gmail.com
REAL_MAIL_PORT=587
REAL_MAIL_USERNAME=null
REAL_MAIL_PASSWORD=null

SANDBOX_MAIL_SCHEME=tls
SANDBOX_MAIL_HOST=sandbox.smtp.mailtrap.io
SANDBOX_MAIL_PORT=2525
SANDBOX_MAIL_USERNAME=null
SANDBOX_MAIL_PASSWORD=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Default password for users created by bulk patient import (change in production)
IMPORT_DEFAULT_PASSWORD=Importado123!
